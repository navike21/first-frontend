# Copy this file to .env and fill in the values
# All VITE_ variables are replaced at build time (client-visible)

VITE_APP_NAME=first

# Auth provider:
#   fake → local dev, validates against VITE_FAKE_USERNAME / VITE_FAKE_PASSWORD
#   api  → calls VITE_API_BASE_URL/api/v1/auth/login (use in staging/prod)
VITE_AUTH_PROVIDER=fake

# Fake credentials — only used when VITE_AUTH_PROVIDER=fake
VITE_FAKE_USERNAME=
VITE_FAKE_PASSWORD=

# Backend base URL — leave empty for fake mode, set to Vercel URL for api mode
# Example: https://first-backend.vercel.app
VITE_API_BASE_URL=

# Cache buster — bump this on each deploy to invalidate persisted IndexedDB cache
VITE_APP_VERSION=1
