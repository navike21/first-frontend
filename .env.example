# Copia este archivo a .env y ajusta los valores según el ambiente
# Todas las variables VITE_ son reemplazadas en build time (visibles en el cliente)
# Ver CLAUDE.md → "Ambientes" para el detalle completo de development/test/producción

VITE_APP_NAME=first

# ─── Auth provider ────────────────────────────────────────────────────────────
#   fake → valida contra VITE_FAKE_USERNAME / VITE_FAKE_PASSWORD, sin backend
#   api  → llama a VITE_API_BASE_URL/api/v1/auth/login
VITE_AUTH_PROVIDER=api

# Credenciales fake — solo se usan cuando VITE_AUTH_PROVIDER=fake
VITE_FAKE_USERNAME=
VITE_FAKE_PASSWORD=

# ─── Backend URLs ─────────────────────────────────────────────────────────────
# Development (local) apunta SIEMPRE al backend de test — nunca a producción,
# para no tocar datos reales durante el desarrollo del día a día.
VITE_API_BASE_URL=https://first-backend-git-test-navike21.vercel.app/api/v1
VITE_SOCKET_URL=https://first-backend-git-test-navike21.vercel.app

# ─── Cache buster ─────────────────────────────────────────────────────────────
# Incrementar en cada deploy para invalidar el caché persistido en IndexedDB
VITE_APP_VERSION=1

# ─── Referencia de ambientes Vercel (configurar en el dashboard/CLI, no aquí) ─
#
#   Ambiente     | Frontend                                    | Backend (VITE_API_BASE_URL)
#   ─────────────┼──────────────────────────────────────────────┼────────────────────────────────────────────────────
#   Development  | local (pnpm dev, localhost:5176)             | https://first-backend-git-test-navike21.vercel.app
#   Test         | https://first-frontend-git-test-navike21.vercel.app | https://first-backend-git-test-navike21.vercel.app
#   Production   | https://first-frontend-rose.vercel.app       | https://first-backend-alpha.vercel.app
#
#   Development NUNCA corre un backend local — siempre habla con el backend de
#   test desplegado (más liviano que levantar Mongo/backend en la laptop).
#   Las URLs -git-test- son ramas persistentes (ver TEST_BRANCH.md en ambos
#   repos), no deployments efímeros de PR.
#
#   Nota: las URLs -git-<branch>- quedan detrás del SSO de Vercel (protección
#   de deployment por defecto, igual que cualquier alias que no sea el dominio
#   de producción) — accesibles para el equipo logueado en Vercel, no público.
#
#   WHITELISTED_DOMAINS en first-backend debe incluir la URL del frontend
#   correspondiente para que CORS acepte las peticiones.
