# Copia este archivo a .env y ajusta los valores según el ambiente
# Todas las variables VITE_ son reemplazadas en build time (visibles en el cliente)

VITE_APP_NAME=first

# ─── Auth provider ────────────────────────────────────────────────────────────
#   fake → local dev, valida contra VITE_FAKE_USERNAME / VITE_FAKE_PASSWORD
#   api  → llama a VITE_API_BASE_URL/api/v1/auth/login
VITE_AUTH_PROVIDER=fake

# Credenciales fake — solo se usan cuando VITE_AUTH_PROVIDER=fake
VITE_FAKE_USERNAME=
VITE_FAKE_PASSWORD=

# ─── Backend URLs ─────────────────────────────────────────────────────────────
#
#   develop  → https://first-backend-git-develop-navike21.vercel.app
#   test     → https://first-backend-git-release-navike21.vercel.app
#   prod     → https://first-backend-alpha.vercel.app
#
#   Todos exponen /api/v1 para REST y la raíz (/) para Socket.IO
#
VITE_API_BASE_URL=
VITE_SOCKET_URL=

# ─── Cache buster ─────────────────────────────────────────────────────────────
# Incrementar en cada deploy para invalidar el caché persistido en IndexedDB
VITE_APP_VERSION=1

# ─── Referencia de ambientes Vercel (configurar en el dashboard, no aquí) ─────
#
#   Environment    | VITE_AUTH_PROVIDER | VITE_API_BASE_URL / VITE_SOCKET_URL
#   ───────────────┼────────────────────┼────────────────────────────────────
#   Production     | api                | https://first-backend-alpha.vercel.app
#   Preview/test   | api                | https://first-backend-git-release-navike21.vercel.app
#   Preview/dev    | api                | https://first-backend-git-develop-navike21.vercel.app
#   Local          | fake               | https://first-backend-git-develop-navike21.vercel.app
#
#   WHITELISTED_DOMAINS en first-backend debe incluir la URL del frontend
#   para que CORS acepte las peticiones.
