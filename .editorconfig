# EditorConfig is awesome: https://editorconfig.org

# Root project configuration
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = auto
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript/TypeScript/React files
[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 80

# JSON files
[*.json]
indent_size = 2
trim_trailing_whitespace = false

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.yml]
indent_size = 2

# CSS, SCSS, and LESS files
[*.{css,scss,less}]
indent_size = 2
