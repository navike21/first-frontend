{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.autoSave": "onWindowChange",
  "eslint.format.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "cSpell.words": [
    "ciphertext",
    "hsla",
    "jdbc",
    "lordicon",
    "lottie",
    "lottiefiles",
    "postgres",
    "postgresql",
    "sonarnetwork",
    "sonarqube",
    "sonarsource",
    "TMUI"
  ]
}
